# Hospital MCP bind address
MEDASSIST_MCP_HOST=0.0.0.0
MEDASSIST_MCP_PORT=9123
MEDASSIST_MCP_PATH=/mcp

# Target TEE secure session endpoint
MEDASSIST_TEE_TARGET=10.17.41.88:50051

# Hospital identity sent during attestation
MEDASSIST_HOSPITAL_ORG_ID=hospital-a

# TCP connect/read timeout in seconds
MEDASSIST_TEE_TIMEOUT_SECONDS=10.0

# Local workflow context lifetime in seconds
MEDASSIST_CONTEXT_TTL_SECONDS=10800
